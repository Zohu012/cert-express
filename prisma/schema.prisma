generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model SourcePdf {
  id           String    @id @default(uuid())
  filename     String
  issueDate    DateTime
  downloadUrl  String?
  status       String    @default("pending")
  totalPages   Int       @default(0)
  companyCount Int       @default(0)
  error        String?
  createdAt    DateTime  @default(now())
  processedAt  DateTime?
  companies    Company[]
}

model Company {
  id             String    @id @default(uuid())
  companyName    String
  dbaName        String?
  streetAddress  String?
  city           String?
  state          String?
  zipCode        String?
  usdotNumber    String
  documentNumber String
  documentType   String
  serviceDate    DateTime
  pdfFilename     String?
  previewFilename String?
  email           String?
  emailSentAt    DateTime?
  emailStatus    String?
  sourcePdfId    String
  sourcePdf      SourcePdf @relation(fields: [sourcePdfId], references: [id])
  orders         Order[]
  emailLogs      EmailLog[]
  excluded       ExcludedCompany?
  createdAt      DateTime  @default(now())

  @@unique([usdotNumber, documentNumber])
  @@index([usdotNumber])
  @@index([documentNumber])
  @@index([companyName])
  @@index([serviceDate])
  @@index([emailStatus])
}

model Order {
  id            String    @id @default(uuid())
  companyId     String
  company       Company   @relation(fields: [companyId], references: [id])
  amount        Int
  currency      String    @default("USD")
  paymentMethod String
  paymentId     String?
  status        String    @default("pending")
  customerEmail String?
  downloadToken String    @unique @default(uuid())
  downloadCount Int       @default(0)
  maxDownloads  Int       @default(5)
  expiresAt        DateTime
  ipAddress        String?
  termsAcceptedAt  DateTime?
  termsVersion     String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([paymentId])
  @@index([downloadToken])
  @@index([status])
}

model EmailLog {
  id          String    @id @default(uuid())
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Restrict)
  toEmail     String
  subject     String
  sentAt      DateTime  @default(now())
  clickCount  Int       @default(0)
  lastClickAt DateTime?
  openCount   Int       @default(0)
  firstOpenAt DateTime?
  status      String    @default("sent")   // "sent" | "failed" | "skipped"
  skipReason  String?                       // "excluded" | "already_sent" | "outside_date_range" | "blocklist" | "invalid_email" | "unsubscribed"
  source      String    @default("manual") // "manual" | "auto"

  @@index([companyId])
  @@index([sentAt])
  @@index([status])
  @@index([source])
}

model ExcludedCompany {
  id         String   @id @default(uuid())
  companyId  String   @unique
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  excludedAt DateTime @default(now())

  @@index([excludedAt])
}

model Setting {
  id    String @id @default(uuid())
  key   String @unique
  value String
}

model AdminUser {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model OtruckingCompany {
  id                String    @id @default(uuid())
  usdotNumber       String    @unique
  sourceUrl         String?

  // Contact Info
  companyName       String?
  physicalAddress   String?
  city              String?
  state             String?
  zipCode           String?
  phone             String?
  email             String?
  companyOfficer    String?

  // Status
  dotStatus         String?
  entityType        String?
  estYear           String?
  powerUnits        String?
  drivers           String?
  safetyRating      String?

  // Authority
  authorityStatus   String?
  authoritySince    String?

  // Business Details
  carrierType       String?
  hazmat            String?
  passengerCarrier  String?
  mcs150Update      String?
  county            String?

  // Fleet / Cargo / Equipment (JSON strings)
  fleetBreakdown    String?
  cargoTypes        String?
  equipmentTypes    String?

  // Scrape metadata
  scrapeStatus      String    @default("pending")
  scrapeError       String?
  scrapedAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([usdotNumber])
  @@index([scrapeStatus])
  @@index([email])
}
